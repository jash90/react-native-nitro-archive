{
  "name": "react-native-nitro-archive",
  "version": "1.2.0",
  "description": "React Native Nitro Module for archive operations: tar, tar.bz2, tar.gz, bz2, gz, zip (AES-256), 7z (pack, unpack, list, detect format) with streaming I/O",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "cpp",
    "android",
    "!android/build",
    "!android/.cxx",
    "nitrogen",
    "react-native-nitro-archive.podspec",
    "react-native.config.js",
    "app.plugin.js",
    "nitro.json",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "nitrogen": "nitrogen",
    "typescript": "tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "nitro",
    "tar",
    "bzip2",
    "gzip",
    "tar.bz2",
    "tar.gz",
    "gz",
    "bz2",
    "archive",
    "zip",
    "7z",
    "7zip",
    "aes",
    "encrypt",
    "compress",
    "decompress"
  ],
  "license": "MIT",
  "author": "Bartlomiej Zimny",
  "repository": {
    "type": "git",
    "url": "https://github.com/jash90/react-native-nitro-archive"
  },
  "homepage": "https://github.com/jash90/react-native-nitro-archive#readme",
  "bugs": {
    "url": "https://github.com/jash90/react-native-nitro-archive/issues"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": ">= 0.20.0"
  },
  "devDependencies": {
    "@expo/config-plugins": "^55.0.7",
    "nitrogen": "^0.35.2",
    "react-native-nitro-modules": "^0.35.2",
    "typescript": "^5.5.0"
  }
}
